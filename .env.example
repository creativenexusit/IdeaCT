NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Leave DATABASE_URL blank to run in demo auth mode (see DEMO_ADMIN_EMAIL /
# DEMO_ADMIN_PASSWORD below). Set a real MongoDB connection string here to
# switch to full production auth automatically — no code changes needed.
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority&appName=Cluster0

AUTH_SECRET=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Only used when DATABASE_URL is blank (demo mode). Ignored once a real
# database is configured.
DEMO_ADMIN_EMAIL=admin@ideact.com
DEMO_ADMIN_PASSWORD=Demo@12345

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=
SMTP_FROM_EMAIL=

# Force evaluation in offline demo mode using the premium mock content layer
FORCE_DEMO=
